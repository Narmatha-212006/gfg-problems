class Solution {
    public int firstSearch(int[] arr, int k) {
        int max=-1;
        int count=0;
        for(int i=0;i<arr.length;i++){
            if(arr[i]==k){
               max=i; 
               count++;
            }
            if(count==1){
                return max;
            }
        }
        return -1;
        
    }
}
