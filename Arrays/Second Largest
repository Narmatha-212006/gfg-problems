class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int f=0;
        int s=0;
        if(f>=s){
        for(int i=0;i<arr.length;i++){
            if(arr[i]>f){
                s=f;
                f=arr[i];
            }
            else if(arr[i]>s&&arr[i]!=f){
                s=arr[i];
            }
        }
        System.out.print(s);
        }
        return -1;
        
    }
}
