class Solution {
    int majorityElement(int arr[]) {
        // using  Boyer-Moore Voting Algorithm
        int max=0;
        int count=0;
       for(int i=0;i<arr.length;i++){
           if(count==0){
               max=arr[i];
           }
            count+=(arr[i]==max)?1:-1;
       }
       return max;
    }
} 
